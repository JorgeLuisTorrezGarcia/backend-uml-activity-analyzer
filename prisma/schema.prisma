generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id             String   @id @default(uuid())
  email          String   @unique
  passwordHash   String
  name           String
  geminiApiKey   String?  // Encriptado
  
  ownedDiagrams  Diagram[] 
  collaborations DiagramCollaborator[]
  notifications  Notification[]
  
  // Relaciones inversas BPM
  bpmInstances   ExecutionInstance[] @relation("InstanciasBPM")
  bpmSteps       ExecutionStep[]     @relation("PasosBPM")
}

model Diagram {
  id             String   @id @default(uuid())
  name           String
  content        Json
  
  ownerId        String
  owner          User     @relation(fields: [ownerId], references: [id])
  
  collaborators  DiagramCollaborator[]
  
  // Relaciones inversas BPM
  executionInstances ExecutionInstance[]
  
  updatedAt      DateTime @updatedAt
  createdAt      DateTime @default(now())
}

model DiagramCollaborator {
  id             String   @id @default(uuid())
  diagramId      String
  userId         String
  
  canEdit        Boolean  @default(false)
  canSave        Boolean  @default(false)
  canDelete      Boolean  @default(false)

  diagram        Diagram  @relation(fields: [diagramId], references: [id], onDelete: Cascade)
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([diagramId, userId])
}

model Notification {
  id        String   @id @default(uuid())
  userId    String   
  message   String   
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ==========================================
// MÓDULO BPM: ENGINE & TRACKING
// ==========================================

model ExecutionInstance {
  id             String   @id @default(uuid())
  diagramId      String
  
  status         String   @default("RUNNING") // RUNNING, COMPLETED, FAILED
  startedAt      DateTime @default(now())
  endedAt        DateTime?

  startedById    String
  startedBy      User     @relation("InstanciasBPM", fields: [startedById], references: [id], onDelete: Cascade)

  diagram        Diagram  @relation(fields: [diagramId], references: [id], onDelete: Cascade)
  steps          ExecutionStep[]
}

model ExecutionStep {
  id             String   @id @default(uuid())
  instanceId     String
  
  nodeId         String   // ID del Nodo en el JSON
  laneId         String?  // ID de la Calle en el JSON (Rol)
  
  userId         String
  executedBy     User     @relation("PasosBPM", fields: [userId], references: [id], onDelete: Cascade)

  formData       Json?    // Las respuestas del Form Builder
  artifactsUrls  String[] // URLs de archivos subidos
  
  executedAt     DateTime @default(now())

  instance       ExecutionInstance @relation(fields: [instanceId], references: [id], onDelete: Cascade)
}
